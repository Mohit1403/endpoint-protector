# Application Configuration
NODE_ENV=production
PORT=3000

# Security Configuration
JWT_SECRET=your_super_secure_jwt_secret_change_this_in_production

# VirusTotal API Configuration
VIRUSTOTAL_API_KEY=70011500145c93ff112a530be9fb02488841efa8584175f0d4120e13acc4021c
# Timezone Configuration (set to your local timezone)
TZ=America/New_York

# Application Settings
PENTESTER_NAME=Security Analyst
COMPANY_NAME= AutoPentrix 
# Scan Configuration
DEFAULT_SCAN_TIMEOUT=300
MAX_CONCURRENT_SCANS=5
ENABLE_SCAN_LOGGING=true

# Report Configuration
DEFAULT_REPORT_FORMAT=pdf
REPORT_RETENTION_DAYS=30

# Security Settings
ENABLE_RATE_LIMITING=true
MAX_REQUESTS_PER_MINUTE=60
ENABLE_CORS=true

# Debug and Logging
DEBUG_MODE=false
LOG_LEVEL=info
